{
  "name": "cpulse-tracker",
  "version": "1.0.0",
  "description": "CPulse is a web-based platform that aggregates competitive programming\r data from Codeforces and CodeChef and presents unified leaderboards\r and performance analytics.",
  "main": "backend/src/index.ts",
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "nodemon --config backend/nodemon.json backend/src/server.ts",
    "dev:frontend": "npm --prefix cpulse-frontend start",
    "start": "ts-node backend/src/server.ts",
    "compile": "node node_modules/typescript/bin/tsc -p backend/tsconfig.json",
    "build": "npm run build:frontend",
    "build:backend": "npm run compile",
    "build:frontend": "npm --prefix cpulse-frontend run build",
    "recalculate": "ts-node backend/src/recalculate.ts",
    "vercel-build": "npm run compile && npm run build:frontend",
    "postinstall": "npm install --prefix cpulse-frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abhishekgit01/CPulse-Tracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Abhishekgit01/CPulse-Tracker/issues"
  },
  "homepage": "https://github.com/Abhishekgit01/CPulse-Tracker#readme",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.0.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.0.3",
    "@vercel/node": "^5.5.33",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
